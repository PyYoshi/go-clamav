# Binaries and build artifacts
/bin/
*.test
*.out

# Fuzzing corpus generated locally
/testdata/fuzz/

# Docker runtime directory (unix socket bind mount target)
/docker/run/*
!/docker/run/.gitkeep

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Session / tooling state; the committed Claude Code harness
# (settings, hooks, skills) is re-included explicitly.
.omc/
/.claude/*
!/.claude/settings.json
!/.claude/hooks
!/.claude/hooks/**
!/.claude/skills
!/.claude/skills/**
